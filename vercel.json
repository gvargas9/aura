{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "ignoreCommand": "if [ -d mobile ]; then exit 0; fi",
  "crons": [
    { "path": "/api/cron/subscription-reminders", "schedule": "0 15 * * *" },
    { "path": "/api/cron/low-stock-check", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/abandoned-carts", "schedule": "0 18 * * *" },
    { "path": "/api/cron/demand-forecast", "schedule": "0 3 * * 1" },
    { "path": "/api/cron/churn-scoring", "schedule": "0 4 * * 1" }
  ]
}
